@{
}
@model Tuple<List<Recipe>, List<Recipe>>

<div class="container mt-4">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Home Page</h2>
            <div class="d-flex gap-2">
                <input id="search" type="text" class="form-control form-control-sm" placeholder="Search recipes..." style="width: 220px" />
                <a asp-action="Create1" class="btn btn-sm btn-success">New Recipe</a>
            </div>
        </div>
        <div class="card-body">
            <h5>All Recipes</h5>
            <table class="table table-striped table-hover" id="all-table">
                <thead>
                    <tr>
                        <th>Recipe Name</th>
                        <th style="width:140px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var recipe in Model.Item1)
                    {
                        <tr>
                            <td class="recipe-name">@recipe.Name</td>
                            <td>
                                <a asp-action="RecipePage" asp-route-id="@recipe.Id" class="btn btn-sm btn-primary">View</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Item1.Any())
                    {
                        <tr><td colspan="2" class="text-muted">No recipes available.</td></tr>
                    }
                </tbody>
            </table>

            <h5 class="mt-4">My Recipes</h5>
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Recipe Name</th>
                        <th style="width:140px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var recipe in Model.Item2)
                    {
                        <tr>
                            <td>@recipe.Name</td>
                            <td>
                                <a asp-action="RecipePage" asp-route-id="@recipe.Id" class="btn btn-sm btn-primary">View</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Item2.Any())
                    {
                        <tr><td colspan="2" class="text-muted">You have no recipes yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    (function(){
        var input = document.getElementById('search');
        var table = document.getElementById('all-table');
        if (!input || !table) return;
        input.addEventListener('input', function(){
            var q = (input.value || '').toLowerCase();
            Array.from(table.querySelectorAll('tbody tr')).forEach(function(row){
                var nameCell = row.querySelector('.recipe-name');
                var text = (nameCell ? nameCell.textContent : '').toLowerCase();
                row.style.display = text.indexOf(q) !== -1 ? '' : 'none';
            });
        });
    })();
</script>