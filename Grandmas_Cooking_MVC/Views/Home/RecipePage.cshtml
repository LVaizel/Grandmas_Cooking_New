@* John - RecipePage *@

@model Grandmas_Cooking_MVC.Models.RecipeModels.Recipe

<div class="container mt-4">
    <div class="card">
        <div class="card-header">
            <h2 class="mb-0">Recipe Details</h2>
        </div>

        <div class="card-body">
            @if (Model == null)
            {
                <p>Recipe not found.</p>
            }
            else
            {
                <form asp-action="RecipePage" method="post">
                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3 row">
                        <label class="col-sm-2 col-form-label">Recipe Name</label>
                        <div class="col-sm-10">
                            <p class="form-control-plaintext">@Model.Name</p>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-2 col-form-label">Description</label>
                        <div class="col-sm-10">
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-2 col-form-label">Image</label>
                        <div class="col-sm-10">
                            <input asp-for="ImageUrl" class="form-control" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="Recipe image" class="img-fluid rounded mt-2" style="max-width:400px;" />
                            }
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-2 col-form-label">Owner</label>
                        <div class="col-sm-10">
                            <p class="form-control-plaintext">@Model.UserId</p>
                        </div>
                    </div>

                    <div class="mb-4 row">
                        <label class="col-sm-2 col-form-label">Created</label>
                        <div class="col-sm-10">
                            <p class="form-control-plaintext">@Model.CreatedAt.ToString("u")</p>
                        </div>
                    </div>

                    <section class="card mb-3">
                        <div class="card-header">
                            <h5 class="mb-0">Ingredients</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Ingredients != null && Model.Ingredients.Any())
                            {
                                @for (int i = 0; i < Model.Ingredients.Count; i++)
                                {
                                    <div class="row g-2 align-items-center mb-2">
                                        <input asp-for="Ingredients[i].Id" type="hidden" />
                                        <input asp-for="Ingredients[i].RecipeId" type="hidden" />

                                        <div class="col-sm-7">
                                            <input asp-for="Ingredients[i].Name" class="form-control" placeholder="Ingredient name" />
                                            <span asp-validation-for="Ingredients[i].Name" class="text-danger"></span>
                                        </div>
                                        <div class="col-sm-3">
                                            <div class="input-group">
                                                <input asp-for="Ingredients[i].Portion" type="number" step="0.01" class="form-control" placeholder="Portion" />
                                                <span class="input-group-text">g</span>
                                            </div>
                                            <span asp-validation-for="Ingredients[i].Portion" class="text-danger"></span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No ingredients listed.</p>
                            }
                        </div>
                    </section>

                    <section class="card mb-3">
                        <div class="card-header">
                            <h5 class="mb-0">Steps</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.RecipeSteps != null && Model.RecipeSteps.Any())
                            {
                                @for (int i = 0; i < Model.RecipeSteps.Count; i++)
                                {
                                    <div class="row g-2 align-items-center mb-2">
                                        <input asp-for="RecipeSteps[i].Id" type="hidden" />
                                        <input asp-for="RecipeSteps[i].RecipeId" type="hidden" />

                                        <div class="col-sm-1">
                                            <input asp-for="RecipeSteps[i].StepNumber" class="form-control" readonly />
                                        </div>
                                        <div class="col-sm-11">
                                            <input asp-for="RecipeSteps[i].Instruction" class="form-control" />
                                            <span asp-validation-for="RecipeSteps[i].Instruction" class="text-danger"></span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No steps listed.</p>
                            }
                        </div>
                    </section>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="HomePage" class="btn btn-secondary">Back</a>
                    </div>
                </form>

                <div class="d-flex gap-2 mt-2">
                    <form asp-action="DeleteRecipe" method="post" class="d-inline">
                        <input name="id" value="@Model.Id" type="hidden" />
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this recipe?');">Delete</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
