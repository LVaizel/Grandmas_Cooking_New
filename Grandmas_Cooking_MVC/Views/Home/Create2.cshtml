@{
}
@model Tuple<Grandmas_Cooking_MVC.Models.RecipeModels.Recipe, Grandmas_Cooking_MVC.Models.RecipeModels.TempRecipe>

<div class="container mt-4">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="mb-0">New Recipe Details</h2>
            <a asp-action="HomePage" class="btn btn-sm btn-secondary">Back</a>
        </div>
        <div class="card-body">
            <form asp-action="Create2" method="post" class="row g-3">
                <div class="col-12">
                    <label class="form-label">Recipe Name</label>
                    <input type="text" name="Name" value="@Model.Item1.Name" class="form-control" />
                </div>

                <div class="col-12">
                    <label class="form-label">Image URL</label>
                    <input type="text" name="ImageUrl" value="@Model.Item1.ImageUrl" class="form-control" />
                </div>

                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea name="Description" class="form-control" rows="3">@Model.Item1.Description</textarea>
                </div>

                <div class="col-12">
                    <h5>Ingredients</h5>
                    @for (int i = 0; i < Model.Item2.NumIngredients; i++)
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-8">
                                <input type="text" name="Ingredients[@i].Name" class="form-control" placeholder="Ingredient name" />
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input type="number" name="Ingredients[@i].Portion" step="0.01" class="form-control" placeholder="Portion" />
                                    <span class="input-group-text">g</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="col-12">
                    <h5>Steps</h5>
                    @for (int i = 0; i < Model.Item2.NumSteps; i++)
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-2">
                                <input type="hidden" name="RecipeSteps[@i].StepNumber" value="@(i + 1)" />
                                <input type="text" value="@(i + 1)" class="form-control" readonly />
                            </div>
                            <div class="col-md-10">
                                <input type="text" name="RecipeSteps[@i].Instruction" class="form-control" placeholder="Step instruction" />
                            </div>
                        </div>
                    }
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create Recipe</button>
                    <a asp-action="HomePage" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>