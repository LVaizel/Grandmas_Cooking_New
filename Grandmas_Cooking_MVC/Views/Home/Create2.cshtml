@{
}
@model Recipe

<div class="container mt-4">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="mb-0">New Recipe Details</h2>
            <a asp-action="HomePage" class="btn btn-sm btn-secondary">Back</a>
        </div>
        <div class="card-body">
            <form asp-action="Create2" method="post" class="row g-3">
                <div class="col-12">
                    <label class="form-label">Recipe Name</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="col-12">
                    <label class="form-label">Image URL</label>
                    <input asp-for="ImageUrl" class="form-control" />
                </div>

                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="col-12">
                    <h5>Ingredients</h5>
                    @for ( int i = 0; i < Model.Ingredients.Count; i++ )
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-8">
                                <input asp-for="Ingredients[i].Name" class="form-control" placeholder="Ingredient name" />
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input asp-for="Ingredients[i].Portion" type="number" step="0.01" class="form-control" placeholder="Portion" />
                                    <span class="input-group-text">g</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="col-12">
                    <h5>Steps</h5>
                    @for ( int i = 0; i < Model.RecipeSteps.Count; i++ )
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-2">
                                <input type="hidden" asp-for="RecipeSteps[i].StepNumber" value="@(i + 1)" />
                                <input type="text" class="form-control" value="@(i + 1)" readonly />
                            </div>
                            <div class="col-md-10">
                                <input asp-for="RecipeSteps[i].Instruction" class="form-control" placeholder="Step instruction" />
                                <input type="hidden" asp-for="RecipeSteps[i].Id" />
                                <input type="hidden" asp-for="RecipeSteps[i].RecipeId" />
                            </div>
                        </div>
                    }
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create Recipe</button>
                    <a asp-action="HomePage" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>